# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
# Model used by the agent nodes (default: claude-opus-4-8)
RAG_MODEL=claude-opus-4-8

# --- Embeddings (Voyage AI — Anthropic's recommended embeddings partner) ---
VOYAGE_API_KEY=pa-...
RAG_EMBED_MODEL=voyage-3.5
RAG_EMBED_DIM=1024

# --- Vector store (Supabase Postgres + pgvector) ---
# Use the "Session/Transaction pooler" connection string from Supabase → Project → Database.
DATABASE_URL=postgresql://postgres:password@db.<ref>.supabase.co:5432/postgres

# --- Web research (Firecrawl) — optional; the researcher node is skipped if unset ---
FIRECRAWL_API_KEY=fc-...

# --- Graph behaviour ---
RAG_TOP_K=5
RAG_MAX_REVISIONS=1

# --- MCP transport: stdio (default) | http ---
RAG_TRANSPORT=stdio
RAG_HTTP_HOST=0.0.0.0
RAG_HTTP_PORT=8000
